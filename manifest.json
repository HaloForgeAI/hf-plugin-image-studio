{
  "$schema": "https://haloforge.dev/schemas/plugin/v1.json",
  "id": "dev.haloforge.image-studio",
  "name": "Image Studio",
  "version": "0.1.13",
  "description": "Professional OpenAI-compatible image generation workspace for HaloForge.",
  "long_description": "Adds a top-level Image Studio module with prompt-driven image generation, reference images, edit mode, task history, HaloForge Cloud gateway support, custom endpoint fallback, and export workflows.",
  "author": "HaloForge Team",
  "homepage": "https://haloforge.dev/catalog/plugins/image-studio",
  "license": "MIT",
  "keywords": ["image", "generation", "openai", "cloud", "studio"],
  "icon": "assets/icon.svg",
  "compatibility": {
    "min_app_version": "0.8.0",
    "min_host_api_version": "0.2.13",
    "platforms": ["windows", "macos", "linux"]
  },
  "host_capabilities": ["navigation", "theme_read", "event_subscribe", "enterprise_gateway", "file_dialogs"],
  "capability_levels": [0],
  "integration": {
    "level0": {
      "module_id": "image-studio",
      "module_label": "Image Studio",
      "module_icon": "Image",
      "sidebar_position": "main",
      "sidebar_order": 24,
      "panel_entry": "dist/index.js"
    }
  },
  "window": {
    "default_open_mode": "reuse_or_new",
    "reuse_key": "plugin",
    "allow_multiple": false
  },
  "entry": {
    "native": {},
    "frontend": "dist/index.js",
    "frontend_styles": "dist/styles.css"
  },
  "permissions": [
    { "type": "host_navigation" },
    { "type": "host_theme_read" },
    { "type": "host_event_subscribe" },
    { "type": "host_enterprise_gateway_access" },
    { "type": "host_file_dialogs" },
    { "type": "filesystem_write" },
    { "type": "network_http" }
  ],
  "settings_schema": {
    "type": "object",
    "properties": {
      "default_model": {
        "type": "string",
        "title": "Default image model",
        "default": "gpt-image-2"
      },
      "default_size": {
        "type": "string",
        "title": "Default image size",
        "default": "1024x1024"
      },
      "gateway_mode": {
        "type": "string",
        "title": "Gateway mode",
        "default": "auto",
        "enum": ["auto", "cloud", "custom"]
      },
      "api_mode": {
        "type": "string",
        "title": "API mode",
        "default": "images",
        "enum": ["images", "responses"]
      },
      "codex_cli": {
        "type": "boolean",
        "title": "Codex CLI compatibility",
        "default": false
      },
      "response_format_b64_json": {
        "type": "boolean",
        "title": "Request base64 image output",
        "default": false
      }
    }
  },
  "commands": [
    {
      "id": "image_studio_generate_images",
      "description": "Send an OpenAI-compatible image generation request through the Image Studio backend."
    },
    {
      "id": "image_studio_edit_images",
      "description": "Send an OpenAI-compatible image edit request through the Image Studio backend."
    },
    {
      "id": "image_studio_write_image_file",
      "description": "Write a generated image to a host-selected file path."
    }
  ]
}
